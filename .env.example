# === DOMAINS ===
# Public domain for Pocket ID (OIDC provider) — also serves the shared sign-in page
AUTH_DOMAIN=auth.example.com
# Base domain (used for cookie sharing across subdomains)
BASE_DOMAIN=example.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com

# Protected apps are declared in the Caddyfile — use setup.sh or edit it directly.

# === OIDC (set after Pocket ID first boot — see README) ===
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# === SECRETS ===
# Generate with: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
COOKIE_SECRET=
# Generate with: openssl rand -base64 32
POCKET_ID_ENCRYPTION_KEY=
